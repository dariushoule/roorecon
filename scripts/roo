#!/usr/bin/env bash
#
# roo — containerized tooling dispatcher for RooRecon.
#
# Runs a CTF/pentest CLI inside its minimal per-tool image so it behaves the
# same on any host. Images are built on demand from docker/<tool>/Dockerfile
# (see scripts/lib/image.sh).
#
# Usage:
#   scripts/roo <tool> [args...]
#   scripts/roo nmap -sCV -p- 10.10.10.5
#
# The current directory is mounted at /work (the container's workdir), so file
# output (e.g. nmap -oA) lands back on the host relative to where you ran roo.
#
# Networking:
#   By default tools use docker's bridge network. To reach a VPN-only target
#   portably (Windows/macOS Docker Desktop can't route to a host tun), bring up
#   the VPN sidecar (scripts/vpn up) and join its netns:
#     ROO_NET=container:roorecon-vpn scripts/roo nmap ...
#
# Host overrides:
#   The host's /etc/hosts does NOT reach containers. Put vhost/name mappings in
#   ./hosts (same format as /etc/hosts); roo merges them with the standard
#   localhost lines and mounts the result into every tool container. This works
#   in both bridge and VPN (--network container:) modes, where --add-host would
#   be rejected. Override the path with ROO_HOSTS.
#
# Authorized targets only — CTF boxes, lab ranges, or signed-scope hosts.

set -euo pipefail

err() { printf '\033[31m[!]\033[0m %s\n' "$*" >&2; }

# shellcheck source=lib/image.sh
source "$(dirname "${BASH_SOURCE[0]}")/lib/image.sh"

usage() {
  cat >&2 <<EOF
Usage: $(basename "$0") <tool> [args...]

  <tool>   a CLI with a Dockerfile under docker/<tool>/ (e.g. nmap)
  [args]   passed straight through to the tool

Examples:
  $(basename "$0") nmap --version
  $(basename "$0") nmap -sCV -p- 10.10.10.5

Env:
  ROO_NET=<spec>   docker --network for the tool (e.g. container:roorecon-vpn)
EOF
  exit 2
}

[ $# -ge 1 ] || usage
TOOL="$1"; shift

# --- per-tool docker flags (registry) --------------------------------------
# Network scanners need raw-socket capabilities for SYN scans, OS detection,
# etc. Add new tools here as needed; default is no extra flags.
EXTRA_FLAGS=()
case "$TOOL" in
  nmap)
    EXTRA_FLAGS=(--cap-add=NET_RAW --cap-add=NET_ADMIN)
    ;;
esac

if ! command -v docker >/dev/null 2>&1; then
  err "docker not found. RooRecon runs all tooling in containers — install docker."
  exit 1
fi

IMAGE="$(roo_ensure_image "$TOOL")" || exit 1

# --- run --------------------------------------------------------------------
# Allocate a TTY only when actually attached to one (so piped/redirected
# callers like recon-host.sh aren't broken).
TTY_FLAGS=()
if [ -t 0 ] && [ -t 1 ]; then
  TTY_FLAGS=(-it)
fi

# Optional --network (e.g. join a VPN sidecar's netns for VPN-only targets).
NET_FLAGS=()
if [ -n "${ROO_NET:-}" ]; then
  NET_FLAGS=(--network "$ROO_NET")
fi

# Host overrides: the host's /etc/hosts isn't visible in containers. Merge any
# ./hosts overrides with the standard localhost lines into a generated file and
# bind-mount it as /etc/hosts. A mount (not --add-host) is used so it also works
# under --network container:, where --add-host is rejected.
HOSTS_FLAGS=()
HOSTS_OVERRIDES="${ROO_HOSTS:-./hosts}"
if [ -s "$HOSTS_OVERRIDES" ]; then
  mkdir -p .roo
  {
    echo "127.0.0.1	localhost"
    echo "::1	localhost ip6-localhost ip6-loopback"
    cat "$HOSTS_OVERRIDES"
  } > .roo/etc-hosts
  HOSTS_FLAGS=(-v "$(cd .roo && pwd)/etc-hosts:/etc/hosts:ro")
fi

# The ${arr[@]+"${arr[@]}"} guard keeps empty arrays from tripping `set -u`
# on macOS's bash 3.2.
exec docker run --rm \
  ${TTY_FLAGS[@]+"${TTY_FLAGS[@]}"} \
  ${EXTRA_FLAGS[@]+"${EXTRA_FLAGS[@]}"} \
  ${NET_FLAGS[@]+"${NET_FLAGS[@]}"} \
  ${HOSTS_FLAGS[@]+"${HOSTS_FLAGS[@]}"} \
  -v "$PWD:/work" -w /work "$IMAGE" "$@"
