#!/usr/bin/env bash
#
# vpn — manage the OpenVPN sidecar container for RooRecon.
#
# Holds a VPN tunnel in a long-lived container named "roorecon-vpn". Tool
# containers join its network namespace to route through the tunnel:
#   ROO_NET=container:roorecon-vpn scripts/roo nmap ...
#   ROO_NET=container:roorecon-vpn scripts/recon/recon-host.sh 10.10.10.5
#
# Usage:
#   scripts/vpn up [config.ovpn]   start the tunnel (default: the .ovpn in ./vpn/)
#   scripts/vpn down               stop and remove the sidecar
#   scripts/vpn status             show whether it's connected + the tun address
#
# Configs live in ./vpn/ and are git-ignored — they hold private keys. If the
# config needs credentials, add `auth-user-pass creds.txt` to it and place
# creds.txt alongside (also git-ignored).
#
# Authorized engagements only.

set -euo pipefail

err()  { printf '\033[31m[!]\033[0m %s\n' "$*" >&2; }
info() { printf '\033[36m[*]\033[0m %s\n' "$*"; }
ok()   { printf '\033[32m[+]\033[0m %s\n' "$*"; }

# shellcheck source=lib/image.sh
source "$(dirname "${BASH_SOURCE[0]}")/lib/image.sh"

CONTAINER="roorecon-vpn"
VPN_DIR="${VPN_DIR:-./vpn}"

usage() {
  cat >&2 <<EOF
Usage: $(basename "$0") <up|down|status> [config.ovpn]

  up [config]   start the VPN sidecar (default: the single .ovpn in ${VPN_DIR}/)
  down          stop and remove the sidecar
  status        show connection state and the tunnel address
EOF
  exit 2
}

require_docker() {
  command -v docker >/dev/null 2>&1 || {
    err "docker not found. RooRecon runs the VPN in a container — install docker."
    exit 1
  }
}

is_running() {
  [ "$(docker inspect -f '{{.State.Running}}' "$CONTAINER" 2>/dev/null)" = "true" ]
}

tun_addr() {
  # Echo the tun0 IPv4 address inside the sidecar, or nothing if not up yet.
  docker exec "$CONTAINER" ip -4 -o addr show tun0 2>/dev/null \
    | grep -oE 'inet [0-9.]+' | head -1 | cut -d' ' -f2 || true
}

find_config() {
  # Resolve the config to use: explicit arg, else the lone .ovpn in $VPN_DIR.
  local arg="${1:-}"
  if [ -n "$arg" ]; then
    [ -f "$arg" ] || { err "config not found: $arg"; exit 1; }
    printf '%s\n' "$arg"
    return
  fi
  local matches=()
  if [ -d "$VPN_DIR" ]; then
    while IFS= read -r f; do matches+=("$f"); done \
      < <(find "$VPN_DIR" -maxdepth 1 -name '*.ovpn' -type f | sort)
  fi
  case ${#matches[@]} in
    0) err "no OpenVPN config provided."
       err "Place your .ovpn in ${VPN_DIR}/ (or pass a path), then re-run."
       exit 1 ;;
    1) printf '%s\n' "${matches[0]}" ;;
    *) err "multiple .ovpn files in ${VPN_DIR}/ — pass the one to use:"
       printf '      %s\n' "${matches[@]}" >&2
       exit 1 ;;
  esac
}

cmd_up() {
  require_docker
  local config config_dir config_file image
  config="$(find_config "${1:-}")"
  config_dir="$(cd "$(dirname "$config")" && pwd)"
  config_file="$(basename "$config")"

  image="$(roo_ensure_image openvpn)" || exit 1

  if is_running; then
    info "sidecar already running; replacing it"
  fi
  docker rm -f "$CONTAINER" >/dev/null 2>&1 || true

  info "starting VPN sidecar with ${config_file}"
  # NET_ADMIN + /dev/net/tun are required to create the tunnel device.
  docker run -d --name "$CONTAINER" \
    --cap-add=NET_ADMIN --device /dev/net/tun \
    -v "${config_dir}:/vpn:ro" -w /vpn \
    "$image" --config "$config_file" >/dev/null

  # Wait for tun0 to get an address (or the container to die on a bad config).
  local addr=""
  for _ in $(seq 1 20); do
    if ! is_running; then
      err "sidecar exited — config or credentials likely wrong. Logs:"
      docker logs --tail 20 "$CONTAINER" >&2 || true
      exit 1
    fi
    addr="$(tun_addr)"
    [ -n "$addr" ] && break
    sleep 1
  done

  if [ -z "$addr" ]; then
    err "tunnel did not come up within 20s. Check: docker logs $CONTAINER"
    exit 1
  fi
  ok "VPN up — tunnel address ${addr}"
  echo
  info "route tools through it with:  ROO_NET=container:${CONTAINER} scripts/roo <tool> ..."
}

cmd_down() {
  require_docker
  if docker rm -f "$CONTAINER" >/dev/null 2>&1; then
    ok "VPN sidecar stopped"
  else
    info "no VPN sidecar running"
  fi
}

cmd_status() {
  require_docker
  if is_running; then
    local addr; addr="$(tun_addr)"
    if [ -n "$addr" ]; then
      ok "VPN connected — tunnel address ${addr}"
    else
      info "sidecar running but tun0 has no address yet"
    fi
  else
    info "VPN sidecar is not running (scripts/vpn up to start it)"
  fi
}

[ $# -ge 1 ] || usage
ACTION="$1"; shift || true
case "$ACTION" in
  up)     cmd_up "${1:-}" ;;
  down)   cmd_down ;;
  status) cmd_status ;;
  *)      usage ;;
esac
