# Scan output / loot — never commit target data
recon-results/
loot/
exploit/
scratch/
*.nmap
*.gnmap
*.xml

# OpenVPN configs, creds, and keys — never commit (secrets + target data)
vpn/*
!vpn/.gitkeep

# Per-engagement /etc/hosts overrides and roo's generated artifacts
hosts
.roo/

# Playwright MCP runtime scratch (browser snapshots, console logs, screenshots)
.playwright-mcp/

# Local Claude Code settings (per-user; keep settings.json shared)
.claude/settings.local.json

# OS / editor / swamp cruft
.DS_Store
*.swp
nul

# Python
__pycache__/
*.pyc
*.pyo
# Kerberos ccaches (tickets = secrets)
*.ccache

